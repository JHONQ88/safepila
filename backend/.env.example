# SafePILA Backend Configuration
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS (comma separated origins, or * for all)
CORS_ORIGINS=*

# File upload
MAX_FILE_SIZE=26214400

# Scoring weights
WEIGHT_METADATA=35
WEIGHT_DATES=30
WEIGHT_STRUCTURE=35
WEIGHT_AI=15

# Semaphore thresholds
SCORE_GREEN_MAX=20
SCORE_YELLOW_MAX=50

# Date tolerance
DATE_TOLERANCE_MINUTES=5